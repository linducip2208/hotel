{
    "name": "hotelhub/hms",
    "type": "project",
    "description": "Hotel Management System — Laravel 11 (Indonesia, BYOK, pSEO).",
    "keywords": ["laravel", "hotel", "pms", "channel-manager", "indonesia"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-bcmath": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "barryvdh/laravel-dompdf": "^3.1",
        "dompdf/dompdf": "^3.1",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image-laravel": "^4.0",
        "laravel/framework": "^11.31",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.11",
        "laravel/tinker": "^2.10",
        "league/flysystem-aws-s3-v3": "^3.29",
        "meilisearch/meilisearch-php": "^1.10",
        "phpoffice/phpspreadsheet": "^5.7",
        "pragmarx/google2fa-laravel": "^3.0",
        "predis/predis": "^2.2",
        "ramsey/uuid": "^4.7",
        "sentry/sentry-laravel": "^4.25",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-permission": "^6.10",
        "spatie/laravel-sluggable": "^3.6"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.36",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.5",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0",
        "spatie/laravel-ignition": "^2.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
