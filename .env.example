APP_NAME="HotelHub HMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_MODE=standalone

# 'standalone' = single tenant, license one-time. 'saas' = multi-tenant with stancl/tenancy.

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hotel_main
DB_USERNAME=root
DB_PASSWORD=

# ─── Redis (Cache, Session, Queue) ────────────────────────────
# Pure Laravel + MySQL setup — Redis NOT required.
# If you do install Redis later, set CACHE_STORE=redis, QUEUE_CONNECTION=redis,
# REDIS_CLIENT=predis, REDIS_HOST=127.0.0.1, REDIS_PORT=6379.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# ─── Session ──────────────────────────────────────────────────
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=true   # set false di local dev (HTTP), wajib true saat production HTTPS

# ─── Broadcasting ─────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Filesystem ───────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Mail (BYOK — user input via admin UI) ─────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Search (Meilisearch) ─────────────────────────────────────
# Default: database driver (MySQL LIKE queries), no external service.
# To switch to Meilisearch: SCOUT_DRIVER=meilisearch + set MEILISEARCH_HOST/KEY.
SCOUT_DRIVER=database
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# ─── License (vendor server + marketplace pairing v3) ─────────
# Vendor licensing (HotelHub tenant activation)
LICENSE_VENDOR_BASE_URL=https://vendor.hotelhub.id
LICENSE_PUBLIC_KEY_PATH=config/license/vendor-public.pem
LICENSE_PUBLIC_KEY_HASH=
LICENSE_GRACE_DAYS=30

# whitelabel.co.id marketplace pairing v3 (buyer activation)
LICENSE_SERVER_URL=https://whitelabel.co.id
LICENSE_DEV_BYPASS=true        # set false di production!
LICENSE_HEARTBEAT_INTERVAL=86400
LICENSE_HEARTBEAT_GRACE=604800

# ─── Storage (S3-compatible BYOK; default local for dev) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-3
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── pSEO ─────────────────────────────────────────────────────
PSEO_ENABLED=true
PSEO_DEFAULT_LOCALE=id

# ─── Coretax (e-Faktur DJP Indonesia) ─────────────────────────
CORETAX_BASE_URL=https://api.coretaxdjp.pajak.go.id
CORETAX_CERT_PATH=storage/app/certificates/
CORETAX_CERT_PASSWORD=
CORETAX_NPWP=
CORETAX_TIMEOUT=30
CORETAX_RETRY=3
CORETAX_ENVIRONMENT=development   # production untuk live

# ─── Sentry (Error Tracking — optional) ───────────────────────
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# ─── Pusher (Realtime Broadcast — optional) ───────────────────
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
